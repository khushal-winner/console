{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "replicaCount": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of replicas"
    },
    "image": {
      "type": "object",
      "properties": {
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"],
          "description": "Image pull policy"
        }
      }
    },
    "service": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["ClusterIP", "NodePort", "LoadBalancer"],
          "description": "Service type"
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535,
          "description": "Service port"
        }
      }
    },
    "route": {
      "type": "object",
      "properties": {
        "tls": {
          "type": "object",
          "properties": {
            "termination": {
              "type": "string",
              "enum": ["edge", "passthrough", "reencrypt"],
              "description": "TLS termination type"
            },
            "insecureEdgeTerminationPolicy": {
              "type": "string",
              "enum": ["Redirect", "Allow", "None"],
              "description": "Insecure edge termination policy"
            }
          }
        }
      }
    },
    "backup": {
      "type": "object",
      "properties": {
        "retentionCount": {
          "type": "integer",
          "minimum": 1,
          "description": "Number of backups to retain"
        },
        "successfulJobsHistoryLimit": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of successful jobs to keep"
        },
        "failedJobsHistoryLimit": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of failed jobs to keep"
        }
      }
    }
  }
}
